# Django Configuration
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here-minimum-50-chars
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# Database Configuration
# For SQLite (development only):
# DB_ENGINE=django.db.backends.sqlite3

# For PostgreSQL (recommended for production):
DB_ENGINE=django.db.backends.postgresql
DB_NAME=fakenews_db
DB_USER=secure_db_user
DB_PASSWORD=very_strong_database_password_here
DB_HOST=localhost
DB_PORT=5432

# For MySQL:
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=fakenews_db
# DB_USER=root
# DB_PASSWORD=strong_password
# DB_HOST=localhost
# DB_PORT=3306

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# CSRF Configuration
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://yourdomain.com

# JWT Token Configuration
JWT_ACCESS_MINUTES=10
JWT_REFRESH_DAYS=1

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Google OAuth2 (optional - for social authentication)
GOOGLE_OAUTH2_KEY=your-google-oauth2-key
GOOGLE_OAUTH2_SECRET=your-google-oauth2-secret

# OCR Configuration (optional)
TESSERACT_PATH=/usr/bin/tesseract
STRICT_IMAGE_MODE=false

# Debug Mode
DEBUG=false
